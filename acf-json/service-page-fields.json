{
  "key": "group_service_page",
  "title": "Service Page Fields",
  "fields": [
    {
      "key": "field_sp_brand",
      "label": "Brand",
      "name": "_ar_brand",
      "type": "select",
      "choices": {
        "Viking": "Viking"
      },
      "default_value": "Viking",
      "required": 1
    },
    {
      "key": "field_sp_appliance",
      "label": "Appliance Type",
      "name": "_ar_appliance_type",
      "type": "select",
      "choices": {
        "Range": "Range",
        "Refrigerator": "Refrigerator",
        "Dishwasher": "Dishwasher",
        "Cooktop": "Cooktop",
        "Wall Oven": "Wall Oven",
        "Wine Cooler": "Wine Cooler",
        "Freezer": "Freezer",
        "Vent Hood": "Vent Hood"
      },
      "required": 1
    },
    {
      "key": "field_sp_hero_subtitle",
      "label": "Hero Subtitle",
      "name": "_ar_hero_subtitle",
      "type": "textarea",
      "rows": 2,
      "instructions": "Displayed below the H1 on the service page hero."
    },
    {
      "key": "field_sp_body_intro",
      "label": "Body Intro Copy",
      "name": "_ar_body_intro",
      "type": "wysiwyg",
      "instructions": "Leave blank to use auto-generated copy."
    },
    {
      "key": "field_sp_common_issues",
      "label": "Common Issues (repair cards)",
      "name": "_ar_common_issues",
      "type": "repeater",
      "min": 0,
      "max": 9,
      "layout": "table",
      "sub_fields": [
        {
          "key": "field_sp_issue_title",
          "label": "Issue Title",
          "name": "title",
          "type": "text"
        },
        {
          "key": "field_sp_issue_desc",
          "label": "Description",
          "name": "description",
          "type": "textarea",
          "rows": 2
        }
      ]
    },
    {
      "key": "field_sp_services",
      "label": "Services & Pricing",
      "name": "_ar_services",
      "type": "repeater",
      "min": 0,
      "max": 10,
      "layout": "block",
      "sub_fields": [
        {
          "key": "field_sp_svc_name",
          "label": "Service Name",
          "name": "name",
          "type": "text"
        },
        {
          "key": "field_sp_svc_desc",
          "label": "Service Description",
          "name": "description",
          "type": "textarea",
          "rows": 2
        },
        {
          "key": "field_sp_svc_price",
          "label": "Price Range (e.g. $85 – $130)",
          "name": "price_range",
          "type": "text"
        }
      ]
    },
    {
      "key": "field_sp_faqs",
      "label": "FAQs",
      "name": "_ar_faqs",
      "type": "repeater",
      "instructions": "Leave empty to use auto-generated FAQs for this brand/appliance.",
      "layout": "block",
      "sub_fields": [
        {
          "key": "field_sp_faq_q",
          "label": "Question",
          "name": "question",
          "type": "text"
        },
        {
          "key": "field_sp_faq_a",
          "label": "Answer",
          "name": "answer",
          "type": "textarea",
          "rows": 3
        }
      ]
    },
    {
      "key": "field_sp_related_services",
      "label": "Related Services",
      "name": "_ar_related_services",
      "type": "relationship",
      "post_type": [
        "service_page"
      ],
      "filters": [
        "search"
      ],
      "max": 6
    }
  ],
  "location": [
    [
      {
        "param": "post_type",
        "operator": "==",
        "value": "service_page"
      }
    ]
  ],
  "menu_order": 0,
  "position": "normal",
  "style": "default",
  "label_placement": "top",
  "instruction_placement": "label",
  "active": true
}
