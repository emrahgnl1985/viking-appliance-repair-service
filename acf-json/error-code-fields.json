{
  "key": "group_error_code",
  "title": "Error Code Fields",
  "fields": [
    {
      "key": "field_ec_brand",
      "label": "Brand",
      "name": "_ar_brand",
      "type": "select",
      "choices": {
        "Viking": "Viking"
      },
      "default_value": "Viking",
      "required": 1
    },
    {
      "key": "field_ec_appliance",
      "label": "Appliance Type",
      "name": "_ar_appliance_type",
      "type": "select",
      "choices": {
        "Range": "Range",
        "Refrigerator": "Refrigerator",
        "Dishwasher": "Dishwasher",
        "Cooktop": "Cooktop",
        "Wall Oven": "Wall Oven",
        "Wine Cooler": "Wine Cooler",
        "Freezer": "Freezer",
        "Vent Hood": "Vent Hood"
      },
      "required": 1
    },
    {
      "key": "field_ec_code",
      "label": "Error Code",
      "name": "_ar_error_code",
      "type": "text",
      "required": 1,
      "instructions": "e.g. F01, EC03, E10, CT06"
    },
    {
      "key": "field_ec_severity",
      "label": "Severity",
      "name": "_ar_severity",
      "type": "select",
      "choices": {
        "Low": "Low",
        "Medium": "Medium",
        "High": "High",
        "Critical": "Critical"
      },
      "required": 1,
      "instructions": "Low = basic troubleshooting resolves; Medium = professional repair recommended; High = stop use, call technician; Critical = immediate safety risk."
    },
    {
      "key": "field_ec_meaning",
      "label": "What It Means",
      "name": "_ar_code_meaning",
      "type": "wysiwyg",
      "instructions": "Plain-English explanation (1–2 paragraphs). No HTML headings."
    },
    {
      "key": "field_ec_dangerous",
      "label": "Is It Dangerous?",
      "name": "_ar_is_dangerous",
      "type": "select",
      "choices": {
        "no": "No",
        "yes": "Yes — act promptly"
      }
    },
    {
      "key": "field_ec_cost_range",
      "label": "Est. Repair Cost Range",
      "name": "_ar_cost_range",
      "type": "text",
      "instructions": "e.g. $180 – $450"
    },
    {
      "key": "field_ec_when_to_call",
      "label": "When to Call a Technician",
      "name": "_ar_when_to_call",
      "type": "textarea",
      "rows": 3,
      "instructions": "Describe the conditions under which professional service is required for this specific code."
    },
    {
      "key": "field_ec_causes",
      "label": "Common Causes",
      "name": "_ar_causes",
      "type": "repeater",
      "layout": "table",
      "sub_fields": [
        {
          "key": "field_ec_cause_title",
          "label": "Cause Title",
          "name": "title",
          "type": "text"
        },
        {
          "key": "field_ec_cause_desc",
          "label": "Description",
          "name": "description",
          "type": "textarea",
          "rows": 2
        }
      ]
    },
    {
      "key": "field_ec_diy_steps",
      "label": "DIY Troubleshooting Steps",
      "name": "_ar_diy_steps",
      "type": "repeater",
      "layout": "block",
      "sub_fields": [
        {
          "key": "field_ec_step_title",
          "label": "Step Title",
          "name": "title",
          "type": "text"
        },
        {
          "key": "field_ec_step_desc",
          "label": "Step Description",
          "name": "description",
          "type": "textarea",
          "rows": 3
        }
      ]
    },
    {
      "key": "field_ec_related_codes",
      "label": "Related Error Codes",
      "name": "_ar_related_error_codes",
      "type": "relationship",
      "post_type": [
        "error_code"
      ],
      "filters": [
        "search"
      ],
      "max": 5
    },
    {
      "key": "field_ec_faqs",
      "label": "FAQs",
      "name": "_ar_faqs",
      "type": "repeater",
      "instructions": "Leave empty to use auto-generated FAQs.",
      "layout": "block",
      "sub_fields": [
        {
          "key": "field_ec_faq_q",
          "label": "Question",
          "name": "question",
          "type": "text"
        },
        {
          "key": "field_ec_faq_a",
          "label": "Answer",
          "name": "answer",
          "type": "textarea",
          "rows": 3
        }
      ]
    }
  ],
  "location": [
    [
      {
        "param": "post_type",
        "operator": "==",
        "value": "error_code"
      }
    ]
  ],
  "active": true
}
