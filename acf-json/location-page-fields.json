{
  "key": "group_location_page",
  "title": "Location Page Fields",
  "fields": [
    {
      "key": "field_lp_city",
      "label": "City",
      "name": "_ar_city",
      "type": "text",
      "required": 1
    },
    {
      "key": "field_lp_state",
      "label": "State Code",
      "name": "_ar_state",
      "type": "text",
      "required": 1,
      "instructions": "e.g. IL, CA, TX"
    },
    {
      "key": "field_lp_state_full",
      "label": "State Full Name",
      "name": "_ar_state_full",
      "type": "text",
      "instructions": "e.g. Illinois, California"
    },
    {
      "key": "field_lp_hero_subtitle",
      "label": "Hero Subtitle",
      "name": "_ar_hero_subtitle",
      "type": "textarea",
      "rows": 2,
      "instructions": "Short subtitle displayed below the H1 in the hero section."
    },
    {
      "key": "field_lp_body_intro",
      "label": "Body Intro Copy",
      "name": "_ar_body_intro",
      "type": "wysiwyg",
      "instructions": "2–3 paragraphs describing service coverage in this city. Leave blank to use auto-generated copy."
    },
    {
      "key": "field_lp_zip_codes",
      "label": "ZIP Codes (comma-separated)",
      "name": "_ar_zip_codes",
      "type": "textarea",
      "rows": 3,
      "instructions": "e.g. 60614, 60622, 60647"
    },
    {
      "key": "field_lp_neighborhoods",
      "label": "Neighborhoods / Suburbs (comma-separated)",
      "name": "_ar_neighborhoods",
      "type": "textarea",
      "rows": 3,
      "instructions": "Comma-separated list of neighborhood names, e.g. Lincoln Park, Wicker Park, Hyde Park"
    },
    {
      "key": "field_lp_suburbs",
      "label": "Suburbs (comma-separated)",
      "name": "_ar_suburbs",
      "type": "textarea",
      "rows": 3,
      "instructions": "Comma-separated list of suburb names, e.g. Naperville, Evanston, Oak Park"
    },
    {
      "key": "field_lp_faqs",
      "label": "FAQs",
      "name": "_ar_faqs",
      "type": "repeater",
      "layout": "block",
      "sub_fields": [
        {
          "key": "field_lp_faq_q",
          "label": "Question",
          "name": "question",
          "type": "text"
        },
        {
          "key": "field_lp_faq_a",
          "label": "Answer",
          "name": "answer",
          "type": "textarea",
          "rows": 3
        }
      ]
    },
    {
      "key": "field_lp_featured_services",
      "label": "Featured Services",
      "name": "_ar_featured_services",
      "type": "relationship",
      "post_type": [
        "service_page"
      ],
      "max": 8
    }
  ],
  "location": [
    [
      {
        "param": "post_type",
        "operator": "==",
        "value": "location_page"
      }
    ]
  ],
  "active": true
}
